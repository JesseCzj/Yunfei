# LLM provider: 千问走OpenAI兼容接口，故设为openai
LLM_PROVIDER=openai

# 千问（DashScope）配置（替换为你的真实密钥和兼容地址）
OPENAI_API_KEY=sk-bee68724c54e4fa5831a1151827e0226
OPENAI_API_KEY_2=sk-02c447979b1a4455a86ee6f4f142fbb4
OPENAI_API_KEY_3=sk-732e8721e7b94f5db2b8a0686093b8ef
OPENAI_API_KEY_4=sk-79a71e910a474df5b235807463bedee1
OPENAI_API_KEY_5=sk-c86d43073eb642faac0332eb8e4355f1
OPENAI_MODEL=qwen3-max-2026-01-23                 # 文本生成主模型
OPENAI_MODEL_GRAPH=qwen3.5-plus-2026-02-15           # DSAG图生成用的模型（可沿用qwen3-max-2026-01-23）
OPENAI_MODEL_RUNTIME=qwen3.5-plus-2026-02-15          # 运行时模板填充（若追求速度可换qwen-turbo）
OPENAI_MODEL_POLISH=qwen-turbo
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small 
OPENAI_EBD_API_KEY=sk-VRSJfD4YBfyCIoZvdu78WbGpiFcDuOylPvPO4YGbx0RvYZ3S
OPENAI_EBD_BASE_URL=https://poloai.top/v1



DSAG_MATCH_CONFIDENCE_THRESHOLD=0.45

# ===== Init speed =====
DSAG_SKIP_INIT_PAYLOADS=0
DSAG_TREE_CONCURRENT=1
DSAG_TREE_MAX_WORKERS=2
DSAG_TREE_CALL_TIMEOUT_SEC=120

# ===== Agent C alignment =====
DSAG_ALIGN_MAX_WORKERS=5
DSAG_LEAF_ALIGN_CHUNK_SIZE=4
DSAG_ALIGN_CANDIDATE_TOP_K=8
DSAG_ALIGN_MIN_PAIRS_PER_EXPERT=3
DSAG_ALIGN_MIN_MISALIGNED_PER_EXPERT=2

# ===== Fallback coverage for more links =====
DSAG_GAPLINK_MIN_COVERAGE=0.75
DSAG_FORCE_PAIRING_TOP_K=4
DSAG_FORCE_PAIRING_PER_LEAF=2

# optional: payload worker when you switch DSAG_SKIP_INIT_PAYLOADS=0
DSAG_PAYLOAD_MAX_WORKERS=6