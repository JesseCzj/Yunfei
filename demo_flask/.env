# LLM provider: 千问走OpenAI兼容接口，故设为openai
LLM_PROVIDER=openai

# 千问（DashScope）配置（替换为你的真实密钥和兼容地址）
OPENAI_API_KEY=sk-bee68724c54e4fa5831a1151827e0226
OPENAI_MODEL=qwen3-max-2026-01-23                 # 文本生成主模型
OPENAI_MODEL_GRAPH=qwen3.5-plus-2026-02-15           # DSAG图生成用的模型（可沿用qwen3-max-2026-01-23）
OPENAI_MODEL_RUNTIME=qwen3.5-plus-2026-02-15          # 运行时模板填充（若追求速度可换qwen-turbo）
OPENAI_MODEL_POLISH=qwen-turbo
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small 
OPENAI_EBD_API_KEY=sk-VRSJfD4YBfyCIoZvdu78WbGpiFcDuOylPvPO4YGbx0RvYZ3S
OPENAI_EBD_BASE_URL=https://poloai.top/v1



DSAG_MATCH_CONFIDENCE_THRESHOLD=0.45

# 1) 降低对齐重试次数（省时间）
DSAG_TREE_MAX_RETRIES=2

# 2) 提高并发（看你账号限速，先温和提高）
DSAG_ALIGN_MAX_WORKERS=5
DSAG_PAYLOAD_MAX_WORKERS=8

# 3) 增大叶子分块，减少调用轮数
DSAG_LEAF_ALIGN_CHUNK_SIZE=8

# 4) 减少 fallback 配对触发与搜索范围
DSAG_GAPLINK_MIN_COVERAGE=0.55
DSAG_FORCE_PAIRING_TOP_K=2
DSAG_FORCE_PAIRING_PER_LEAF=1